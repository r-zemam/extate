{
  "enabled": true,
  "name": "Test File Reminder",
  "description": "Reminds to create a corresponding test file when a new page or component is created",
  "version": "1",
  "when": {
    "type": "fileCreated",
    "patterns": [
      "app/**/page.tsx",
      "components/**/*.tsx",
      "lib/**/*.ts"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A new file was just created. Check if there is a corresponding test file in the __tests__ directory next to it. If not, remind the user to create one following the naming pattern: 'page.tsx' → '__tests__/page.test.tsx', 'component.tsx' → '__tests__/component.test.tsx', 'utility.ts' → '__tests__/utility.test.ts'. Tests should cover: basic rendering or function output, error cases, and any edge cases specific to the file's purpose. Reference coding-standards.md for test location conventions."
  }
}
